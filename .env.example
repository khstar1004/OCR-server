# Copy this file to .env and edit only .env.
# All Docker profiles and the app runtime use the same .env file.

# Images and ports
APP_IMAGE=a-cong-ocr:chandra
OCR_IMAGE=a-cong-ocr:chandra
VLLM_IMAGE=a-cong-vllm-openai:chandra
API_HOST_PORT=18007
OCR_API_HOST_PORT=18009

# App basics
APP_NAME=news-ocr
APP_ENV=development
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./news_ocr.db
AUTO_CREATE_TABLES=true

# Host paths
WATCH_DIR=./news_pdfs
DATA_DIR=./news_data
MODELS_DIR=./news_models
MODEL_CACHE_DIR=./model_cache
INPUT_ROOT_HOST=./news_pdfs
OUTPUT_ROOT_HOST=./news_output
MODELS_ROOT_HOST=./news_models
INPUT_ROOT=./news_pdfs
OUTPUT_ROOT=./news_output
MODELS_ROOT=./news_models

# OCR defaults: local HF mode for `docker compose up -d`
PDF_RENDER_DPI=300
OCR_BACKEND=chandra
OCR_SERVICE_URL=
OCR_SERVICE_MODE=native
OCR_SERVICE_API_KEY=
OCR_SERVICE_TIMEOUT_SEC=300.0
OCR_SERVICE_POLL_INTERVAL_SEC=2.0
OCR_SERVICE_MARKER_MODE=accurate
OCR_OFFLINE=true
OCR_DEVICE=gpu
OCR_RETRY_LOW_QUALITY=true
OCR_QUALITY_MIN_CHARS=80
OCR_QUALITY_MIN_KOREAN_RATIO=0.35
CHANDRA_METHOD=hf
CHANDRA_MODEL_ID=datalab-to/chandra-ocr-2
CHANDRA_MODEL_DIR=
CHANDRA_PROMPT_TYPE=ocr_layout
CHANDRA_BATCH_SIZE=1
CHANDRA_DEVICE_MAP=auto
CHANDRA_DTYPE=bfloat16

# Optional LLM post-processing
LLM_BASE_URL=
LLM_MODEL=gpt-oss-20b
LLM_API_KEY=
LLM_TIMEOUT_SEC=20

# vLLM / remote-ocr shared settings
OCR_SERVICE_CHANDRA_METHOD=vllm
VLLM_API_BASE=http://vllm-ocr:8000/v1
VLLM_MODEL_NAME=chandra-ocr-2
VLLM_MODEL_PATH=/models/chandra-ocr-2
VLLM_MAX_MODEL_LEN=18000
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MM_PROCESSOR_KWARGS={"min_pixels":3136,"max_pixels":6291456}
MAX_VLLM_RETRIES=6
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Delivery target
CALLBACK_TIMEOUT_SECONDS=30
TARGET_API_BASE_URL=http://121.153.7.193:8000/news
TARGET_API_TOKEN=
TARGET_API_TIMEOUT_SEC=30

# Profile notes
# `docker compose --profile vllm up -d`: set `CHANDRA_METHOD=vllm` and keep `OCR_SERVICE_URL=` blank.
# `docker compose --profile remote-ocr up -d`: the compose file routes app -> ocr-service automatically.
# External OCR server: set `OCR_SERVICE_URL=http://<OCR_IP>:8000` or `http://<OCR_IP>:8000/api/v1`.
