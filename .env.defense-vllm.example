APP_IMAGE=a-cong-ocr:chandra
VLLM_IMAGE=vllm/vllm-openai:v0.17.0

WATCH_DIR=./news_pdfs
DATA_DIR=./news_data
MODELS_DIR=./news_models
MODEL_CACHE_DIR=./model_cache

API_HOST_PORT=18007

OCR_BACKEND=chandra
OCR_SERVICE_URL=
OCR_SERVICE_MODE=native
OCR_OFFLINE=true
OCR_DEVICE=gpu
OCR_RETRY_LOW_QUALITY=true

CHANDRA_METHOD=vllm
CHANDRA_MODEL_ID=datalab-to/chandra-ocr-2
CHANDRA_MODEL_DIR=/models/chandra-ocr-2
CHANDRA_PROMPT_TYPE=ocr_layout
CHANDRA_BATCH_SIZE=1
CHANDRA_DEVICE_MAP=auto
CHANDRA_DTYPE=bfloat16

OCR_SERVICE_CHANDRA_METHOD=vllm
VLLM_API_BASE=http://vllm-ocr:8000/v1
VLLM_MODEL_NAME=chandra-ocr-2
VLLM_MODEL_PATH=/models/chandra-ocr-2
VLLM_MAX_MODEL_LEN=18000
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MM_PROCESSOR_KWARGS={"min_pixels":3136,"max_pixels":6291456}
MAX_VLLM_RETRIES=6

HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
